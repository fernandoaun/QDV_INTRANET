# =============================================================================
# EJEMPLO DE CONFIGURACIÓN LOCAL — copiar a ".env" en esta misma carpeta (project_web)
# PowerShell:  Copy-Item .env.example .env
# CMD:         copy .env.example .env
# =============================================================================

# Entorno Flask (local siempre development)
FLASK_ENV=development

# Clave para sesiones. Este valor es SOLO de ejemplo para desarrollo; cambiá en producción.
SECRET_KEY=dev-ejemplo-no-usar-en-internet-7f3a9c2e1b8d4a6e5c0f9b2d8e1a4c7f

# SQLite local (recomendado): NO definas DATABASE_URL y la app usará automáticamente:
#   project_web/instance/qdv_web.db  (ruta absoluta; no importa desde qué carpeta ejecutes)
#
# Si querés forzar SQLite manualmente en Windows, podés usar una ruta absoluta, por ejemplo:
# DATABASE_URL=sqlite:///C:/ruta/completa/hacia/instance/qdv_web.db
#
# PostgreSQL (solo cuando despliegues o pruebes contra Postgres):
# DATABASE_URL=postgresql+psycopg2://usuario:clave@localhost:5432/nombre_bd

# Puerto del servidor de desarrollo (run.py). Por defecto 5000 si no está definido.
PORT=5000

# Cookies solo por HTTPS (activar en Render/Railway). En local dejar comentado.
# SESSION_COOKIE_SECURE=true

# Opcional — escuchar en toda la red (celular en la misma WiFi). Por defecto run.py usa solo 127.0.0.1
# HOST=0.0.0.0

# Opcional — para atajo: flask run sin --app
# FLASK_APP=run.py

# =============================================================================
# PRODUCCIÓN (Render / Railway / VPS / Docker) — definir en el panel del host, NO en Git
# =============================================================================
# FLASK_ENV=production
# SECRET_KEY=<generá uno largo con: python -c "import secrets; print(secrets.token_hex(32))">
# DATABASE_URL=postgresql://usuario:clave@host:5432/nombre_bd
#   (Render/Railway suelen dar postgres://...; la app lo convierte a postgresql+psycopg2://)
# SESSION_COOKIE_SECURE=true
# PORT=<lo asigna el proveedor, ej. Render/Railway>

# =============================================================================
# API REST (/api/v1) — cliente sin cookies (opcional)
# =============================================================================
# Si definís ambos, las peticiones pueden usar:
#   Authorization: Bearer <API_BEARER_TOKEN>
# El usuario debe existir en `usuarios` y estar activo; los permisos son los de ese usuario (rol + permisos).
# API_BEARER_TOKEN=<generá uno largo, ej. python -c "import secrets; print(secrets.token_urlsafe(32))">
# API_BEARER_USER_ID=<id numérico del usuario de servicio, ej. 2>

# CORS solo para /api/v1 (front en otro origen). Lista separada por comas; vacío = sin CORS.
# Con cookies de sesión, el origen no puede ser *. Ejemplo:
# CORS_ORIGINS=http://127.0.0.1:5173,https://mi-front.example.com

# Límite de solicitudes para /api/v1 (Flask-Limiter). Fuera de /api/v1 no aplica.
# RATELIMIT_ENABLED=false
# RATELIMIT_DEFAULT=120 per minute
# RATELIMIT_API_DEFAULT=120 per minute
#   (alias opcional de RATELIMIT_DEFAULT si preferís el nombre “API”)
# RATELIMIT_STORAGE_URI=memory://
#   En varios workers de Gunicorn conviene Redis, ej. redis://localhost:6379
# Cabeceras X-RateLimit-* en respuestas (útil para clientes / sync). Desactivar: RATELIMIT_HEADERS_ENABLED=false
# RATELIMIT_HEADERS_ENABLED=true

# /api/v1/docs y /api/v1/openapi.json: en production por defecto exigen usuario logueado o Bearer.
# En local (development) por defecto son públicos. Forzar: API_DOCS_REQUIRE_AUTH=true|false
# API_DOCS_REQUIRE_AUTH=false
